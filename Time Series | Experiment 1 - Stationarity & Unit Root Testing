        "#(5)First difference + plots\n",
        "\n",
        "gdp['Delta_GDP']     = gdp['Real_GDP'].diff()\n",
        "gdp['Log_GDP']       = np.log(gdp['Real_GDP'])\n",
        "gdp['Delta_Log_GDP'] = gdp['Log_GDP'].diff()\n",
        "\n",
        "fig, axes = plt.subplots(2, 1, figsize=(12, 7), sharex=True)\n",
        "\n",
        "axes[0].plot(gdp.index, gdp['Delta_GDP'], color='steelblue', linewidth=1)\n",
        "axes[0].axhline(0, color='black', linewidth=0.8, linestyle='--')\n",
        "axes[0].set_title('First Difference of Real GDP', fontweight='bold')\n",
        "axes[0].set_ylabel('Billions USD')\n",
        "\n",
        "axes[1].plot(gdp.index, gdp['Delta_Log_GDP'] * 100, color='darkorange', linewidth=1)\n",
        "axes[1].axhline(0, color='black', linewidth=0.8, linestyle='--')\n",
        "axes[1].set_title('Log-Difference of Real GDP (Approx. Quarterly Growth Rate %)', fontweight='bold')\n",
        "axes[1].set_ylabel('% Change')\n",
        "axes[1].set_xlabel('Date')\n",
        "\n",
        "for s, e in recessions:\n",
        "    for ax in axes:\n",
        "        ax.axvspan(pd.to_datetime(s), pd.to_datetime(e), alpha=0.15, color='red')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
