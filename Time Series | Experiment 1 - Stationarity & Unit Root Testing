        "#(2)Building the dataset & define range\n",
        "\n",
        "start = datetime(1947, 1, 1)\n",
        "end   = datetime(2024, 12, 31)\n",
        "\n",
        "gdp = web.DataReader('GDPC1', 'fred', start, end)\n",
        "gdp.columns = ['Real_GDP']\n",
        "\n",
        "print(f'Observations: {len(gdp)}')\n",
        "print(f'Period: {gdp.index[0].date()} to {gdp.index[-1].date()}')\n",
        "gdp.tail()"
      ]
