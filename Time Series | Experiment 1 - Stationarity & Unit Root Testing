        "#(4)ADF function + test on levels\n",
        "\n",
        "def run_adf(series, label, regression='ct'):\n",
        "    result = adfuller(series.dropna(), autolag='AIC', regression=regression)\n",
        "\n",
        "    adf_stat, p_value, lags_used, n_obs, crit_vals = result[0], result[1], result[2], result[3], result[4]\n",
        "\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Test: {label}\")\n",
        "    print(f\"  Regression spec : '{regression}' ({'constant + trend' if regression=='ct' else 'constant only' if regression=='c' else 'none'})\")\n",
        "    print(f\"  Lags selected   : {lags_used} (AIC criterion)\")\n",
        "    print(f\"  Observations    : {n_obs}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Statistic   : {adf_stat:.4f}\")\n",
        "    print(f\"  p-value         : {p_value:.4f}\")\n",
        "    print(f\"  Critical Values :\")\n",
        "    for conf, cv in crit_vals.items():\n",
        "        reject = '  <-- REJECT H0' if adf_stat < cv else ''\n",
        "        print(f\"      {conf}: {cv:.4f}{reject}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    conclusion = 'REJECT H0 — stationary' if p_value < 0.05 else 'FAIL TO REJECT H0 — unit root (non-stationary)'\n",
        "    print(f\"  Conclusion (5%): {conclusion}\\n\")\n",
        "\n",
        "# Test on levels — 'ct' because GDP has a visible trend\n",
        "run_adf(gdp['Real_GDP'], label='Real GDP (Levels)', regression='ct')"
      ]
