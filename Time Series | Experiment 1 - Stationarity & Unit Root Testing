        "ax.yaxis.set_major_formatter(mtick.FuncFormatter(lambda x, _: f'{x:,.0f}'))\n",
        "\n",
        "for s, e in recessions:\n",
        "    ax.axvspan(pd.to_datetime(s), pd.to_datetime(e), alpha=0.15, color='red')\n",
        "\n",
        "ax.annotate('Recessions shaded in red', xy=(0.01, 0.92), xycoords='axes fraction',\n",
