        "]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 4))\n",
        "ax.plot(gdp.index, gdp['Real_GDP'], color='steelblue', linewidth=1.5)\n",
        "ax.set_title('US Real GDP — Levels (Billions, Chained 2017 USD)', fontweight='bold')\n",
        "ax.set_xlabel('Date')\n",
