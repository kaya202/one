        "def run_adf(series, label, regression='ct'):\n",
        "    \"\"\"\n",
        "    Augmented Dickey-Fuller test with automated interpretation.\n",
        "\n",
        "    regression:\n",
        "      'ct' = constant + trend  -> use when series has visible trend\n",
        "      'c'  = constant only     -> use when series has no trend\n",
        "      'n'  = none              -> rarely used\n",
        "\n",
        "    H0: delta = 0  -> unit root (non-stationary)\n",
        "    H1: delta < 0  -> no unit root (stationary)\n",
        "\n",
        "    Reject H0 when ADF statistic is MORE negative than critical value.\n",
        "    Returns a dictionary of results for use in automated conclusion.\n",
        "    \"\"\"\n",
        "\n",
        "    result    = adfuller(series.dropna(), autolag='AIC', regression=regression)\n",
        "    adf_stat  = result[0]\n",
        "    p_value   = result[1]\n",
        "    lags_used = result[2]\n",
        "    n_obs     = result[3]\n",
        "    crit_vals = result[4]\n",
        "\n",
        "    # Automated decision logic\n",
        "    reject_1pct  = adf_stat < crit_vals['1%']\n",
        "    reject_5pct  = adf_stat < crit_vals['5%']\n",
        "    reject_10pct = adf_stat < crit_vals['10%']\n",
        "\n",
        "    if reject_1pct:\n",
        "        strength   = 'Strong evidence against unit root (significant at 1%)'\n",
        "        stationary = True\n",
        "    elif reject_5pct:\n",
        "        strength   = 'Evidence against unit root (significant at 5%)'\n",
        "        stationary = True\n",
        "    elif reject_10pct:\n",
        "        strength   = 'Weak evidence against unit root (significant at 10% only)'\n",
        "        stationary = True\n",
        "    else:\n",
        "        strength   = 'No evidence against unit root — fail to reject H0'\n",
        "        stationary = False\n",
        "\n",
        "    # Print output\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Test : {label}\")\n",
        "    print(f\"  Spec     : '{regression}' ({'constant + trend' if regression=='ct' else 'constant only' if regression=='c' else 'none'})\")\n",
        "    print(f\"  Lags     : {lags_used} (AIC auto-selected)\")\n",
        "    print(f\"  Obs      : {n_obs}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Statistic   : {adf_stat:.4f}\")\n",
        "    print(f\"  p-value         : {p_value:.4f}\")\n",
        "    print(f\"  Critical Values :\")\n",
        "    for conf, cv in crit_vals.items():\n",
        "        marker = '  <-- REJECT H0' if adf_stat < cv else ''\n",
        "        print(f\"      {conf}: {cv:.4f}{marker}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  Verdict    : {strength}\")\n",
        "    print(f\"  Stationary : {'YES' if stationary else 'NO'}\")\n",
        "    print()\n",
        "\n",
        "    # Return dictionary for use in automated conclusion\n",
        "    return {\n",
        "        'label'      : label,\n",
        "        'adf_stat'   : adf_stat,\n",
        "        'p_value'    : p_value,\n",
        "        'stationary' : stationary,\n",
        "        'lags'       : lags_used\n",
        "    }\n",
        "\n",
        "print('ADF function loaded.')"
      ],
