        "# =============================================================\n",
        "# EXTENSION 1: KPSS Test\n",
        "# Complements ADF by reversing the null hypothesis\n",
        "# H0: stationary   H1: unit root\n",
        "# Running ADF + KPSS together\n",
        "# When both tests agree the conclusion is robust\n",
        "# =============================================================\n",
        "\n",
        "def run_kpss(series, label, regression='ct'):\n",
        "    \"\"\"\n",
        "    KPSS test with automated interpretation.\n",
        "\n",
        "    H0: series is stationary\n",
        "    H1: series has a unit root\n",
        "\n",
        "    Note: opposite null to ADF.\n",
        "    Reject H0 when KPSS statistic is MORE positive than critical value.\n",
        "    Returns dictionary for use in combined ADF+KPSS conclusion.\n",
        "    \"\"\"\n",
        "    stat, p_value, lags, crit_vals = kpss(series.dropna(),\n",
        "                                           regression=regression,\n",
        "                                           nlags='auto')\n",
        "\n",
        "    # Automated decision logic\n",
        "    if p_value < 0.01:\n",
        "        strength   = 'Strong evidence of unit root (significant at 1%)'\n",
        "        stationary = False\n",
        "    elif p_value < 0.05:\n",
        "        strength   = 'Evidence of unit root (significant at 5%)'\n",
        "        stationary = False\n",
        "    elif p_value < 0.10:\n",
        "        strength   = 'Weak evidence of unit root (significant at 10% only)'\n",
        "        stationary = False\n",
        "    else:\n",
        "        strength   = 'No evidence against stationarity — fail to reject H0'\n",
        "        stationary = True\n",
        "\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  KPSS Test : {label}\")\n",
        "    print(f\"  Spec      : '{regression}'\")\n",
        "    print(f\"  H0: stationary  |  H1: unit root\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  KPSS Statistic  : {stat:.4f}\")\n",
        "    print(f\"  p-value         : {p_value:.4f}\")\n",
        "    print(f\"  Critical Values :\")\n",
        "    for conf, cv in crit_vals.items():\n",
        "        marker = '  <-- REJECT H0' if stat > cv else ''\n",
        "        print(f\"      {conf}: {cv:.4f}{marker}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  Verdict    : {strength}\")\n",
        "    print(f\"  Stationary : {'YES' if stationary else 'NO'}\")\n",
        "    print()\n",
        "\n",
        "    return {\n",
        "        'label'      : label,\n",
        "        'stat'       : stat,\n",
        "        'p_value'    : p_value,\n",
        "        'stationary' : stationary\n",
        "    }\n",
        "\n",
        "print('KPSS function loaded.')"
