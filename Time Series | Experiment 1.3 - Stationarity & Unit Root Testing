      "source": [
        "#  Unit Root Intuition\n",
        "\n",
        "np.random.seed(42)\n",
        "n = 200\n",
        "\n",
        "stationary  = np.random.normal(0, 1, n)\n",
        "random_walk = np.cumsum(np.random.normal(0, 1, n))\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n",
        "\n",
        "axes[0].plot(stationary, color='steelblue', linewidth=1)\n",
        "axes[0].axhline(0, color='black', linewidth=0.8, linestyle='--')\n",
        "axes[0].set_title('Stationary Series (White Noise)', fontweight='bold')\n",
        "axes[0].set_ylabel('Value')\n",
        "axes[0].set_xlabel('Time')\n",
        "\n",
        "axes[1].plot(random_walk, color='crimson', linewidth=1)\n",
        "axes[1].axhline(0, color='black', linewidth=0.8, linestyle='--')\n",
        "axes[1].set_title('Non-Stationary Series (Random Walk)', fontweight='bold')\n",
        "axes[1].set_ylabel('Value')\n",
        "axes[1].set_xlabel('Time')\n",
        "\n",
        "plt.suptitle('Unit Root Intuition: Stationary vs Non-Stationary',\n",
        "             fontsize=13, fontweight='bold', y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\"\"\n",
        "- Stationary  : temporary shocks, series go back to mean\n",
        "- Random walk : permanent shocks, series drifts indefinitely\n",
        "\"\"\")"
      ]
