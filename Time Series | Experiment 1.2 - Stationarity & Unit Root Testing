        "# Unit root intuition and graph\n",
        "np.random.seed(42)\n",
        "n = 200\n",
        "\n",
        "stationary  = np.random.normal(0, 1, n)\n",
        "random_walk = np.cumsum(np.random.normal(0, 1, n))\n",
