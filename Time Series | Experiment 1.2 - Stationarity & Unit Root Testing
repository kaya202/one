        "# Reusable ADF function — used throughout this experiment and future notebooks\n",
        "\n",
        "def run_adf(series, label, regression='ct'):\n",
        "    \"\"\"\n",
        "    Run Augmented Dickey-Fuller test.\n",
        "\n",
        "    regression:\n",
        "      'ct' = constant + trend  → use when series has visible upward/downward trend\n",
        "      'c'  = constant only     → use when series has no trend but non-zero mean\n",
        "      'n'  = none              → rarely used in practice\n",
        "\n",
        "    H0: delta = 0  → unit root (non-stationary)\n",
        "    H1: delta < 0  → no unit root (stationary)\n",
        "    Reject H0 when ADF statistic is MORE negative than critical value.\n",
        "    \"\"\"\n",
        "    result     = adfuller(series.dropna(), autolag='AIC', regression=regression)\n",
        "    adf_stat   = result[0]\n",
        "    p_value    = result[1]\n",
        "    lags_used  = result[2]\n",
        "    n_obs      = result[3]\n",
        "    crit_vals  = result[4]\n",
        "\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Test : {label}\")\n",
        "    print(f\"  Spec     : '{regression}' ({'constant + trend' if regression=='ct' else 'constant only' if regression=='c' else 'none'})\")\n",
        "    print(f\"  Lags     : {lags_used} (AIC auto-selected)\")\n",
        "    print(f\"  Obs      : {n_obs}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ADF Statistic   : {adf_stat:.4f}\")\n",
        "    print(f\"  p-value         : {p_value:.4f}\")\n",
        "    print(f\"  Critical Values :\")\n",
        "    for conf, cv in crit_vals.items():\n",
        "        reject = '  <-- REJECT H0' if adf_stat < cv else ''\n",
        "        print(f\"      {conf}: {cv:.4f}{reject}\")\n",
        "    print(f\"{'='*55}\")\n",
        "    conclusion = 'REJECT H0 - stationary' if p_value < 0.05 else 'FAIL TO REJECT H0 - unit root (non-stationary)'\n",
        "    print(f\"  Conclusion (5%): {conclusion}\")\n",
        "    print()"
      ]
    },
